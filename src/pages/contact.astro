---
import Base from "../layouts/Base.astro";
import { site } from "../data/site";

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "ContactPage",
  name: "Contact — Slidell Stitches",
  url: `${site.url}/contact`,
  description:
    "Get in touch with Slidell Stitches. Questions, wholesale inquiries, or custom embroidery requests.",
});
---

<Base
  title="Contact — Slidell Stitches"
  description="Get in touch with Slidell Stitches. Questions, wholesale inquiries, or custom embroidery requests. Based in Slidell, Louisiana."
  schema={schema}
>
  <section class="py-16 px-6 max-w-4xl mx-auto text-center">
    <h1 class="font-serif text-4xl text-charcoal mb-4">Get in Touch</h1>
    <p class="font-body text-charcoal-light text-lg">
      Questions, wholesale inquiries, or just want to say hey — I'd love to hear from you.
    </p>
  </section>

  <section class="pb-16 px-6 max-w-6xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
      <!-- Contact info -->
      <div>
        <h2 class="font-serif text-2xl text-charcoal mb-6">Reach out</h2>
        <ul class="space-y-5 font-body">
          <li class="flex items-start gap-4">
            <span class="flex-shrink-0 w-10 h-10 rounded-full bg-sage-light flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-sage-dark" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                <polyline points="22,6 12,13 2,6"/>
              </svg>
            </span>
            <div>
              <div class="text-charcoal-light text-sm">Email</div>
              <a href={`mailto:${site.email.contact}`} class="text-charcoal hover:text-sage transition-colors duration-200">
                {site.email.contact}
              </a>
            </div>
          </li>

          <li class="flex items-start gap-4">
            <span class="flex-shrink-0 w-10 h-10 rounded-full bg-sage-light flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-sage-dark" fill="currentColor" viewBox="0 0 24 24">
                <path d="M13 22V12h3l1-4h-4V5.5c0-1 .5-2 2-2h2V0h-3c-3 0-5 2-5 5v3H6v4h3v10h4z"/>
              </svg>
            </span>
            <div>
              <div class="text-charcoal-light text-sm">Facebook</div>
              <a href={site.social.facebook} target="_blank" rel="noopener noreferrer" class="text-charcoal hover:text-sage transition-colors duration-200">
                Slidell Stitches
              </a>
            </div>
          </li>

          <li class="flex items-start gap-4">
            <span class="flex-shrink-0 w-10 h-10 rounded-full bg-sage-light flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-sage-dark" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
                <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
                <line x1="3" y1="6" x2="21" y2="6"/>
                <path d="M16 10a4 4 0 0 1-8 0"/>
              </svg>
            </span>
            <div>
              <div class="text-charcoal-light text-sm">Etsy</div>
              <a href={site.social.etsy} target="_blank" rel="noopener noreferrer" class="text-charcoal hover:text-sage transition-colors duration-200">
                etsy.com/shop/slidellstitches
              </a>
            </div>
          </li>

          <li class="flex items-start gap-4">
            <span class="flex-shrink-0 w-10 h-10 rounded-full bg-sage-light flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-sage-dark" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                <circle cx="12" cy="10" r="3"/>
              </svg>
            </span>
            <div>
              <div class="text-charcoal-light text-sm">Location</div>
              <span class="text-charcoal">Slidell, Louisiana</span>
            </div>
          </li>
        </ul>
      </div>

      <!-- Form -->
      <div>
        <h2 class="font-serif text-2xl text-charcoal mb-6">Send a message</h2>
        <form
          id="contact-form"
          action="https://formspree.io/f/placeholder"
          method="POST"
          class="space-y-5"
        >
          <div>
            <label for="name" class="block font-body font-medium text-charcoal mb-2">Name <span class="text-sage">*</span></label>
            <input
              type="text"
              id="name"
              name="name"
              required
              class="w-full rounded-lg border border-sage-light px-4 py-3 focus:ring-2 focus:ring-sage focus:border-sage focus:outline-none"
            />
          </div>

          <div>
            <label for="email" class="block font-body font-medium text-charcoal mb-2">Email <span class="text-sage">*</span></label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full rounded-lg border border-sage-light px-4 py-3 focus:ring-2 focus:ring-sage focus:border-sage focus:outline-none"
            />
          </div>

          <div>
            <label for="message" class="block font-body font-medium text-charcoal mb-2">Message <span class="text-sage">*</span></label>
            <textarea
              id="message"
              name="message"
              required
              rows="5"
              class="w-full rounded-lg border border-sage-light px-4 py-3 focus:ring-2 focus:ring-sage focus:border-sage focus:outline-none"
            ></textarea>
          </div>

          <button
            type="submit"
            class="bg-sage text-white font-body rounded-lg px-8 py-3 hover:bg-sage-dark transition-colors duration-200"
          >
            Send Message
          </button>
        </form>

        <div
          id="contact-success"
          class="hidden mt-8 bg-sage-light rounded-xl p-6 text-center"
        >
          <p class="font-body text-charcoal">
            Thanks for reaching out! I'll get back to you soon. — Stephanie
          </p>
        </div>
      </div>
    </div>
  </section>

  <script is:inline>
    document.addEventListener("DOMContentLoaded", () => {
      const form = document.getElementById("contact-form");
      const success = document.getElementById("contact-success");
      if (form && success) {
        form.addEventListener("submit", (e) => {
          e.preventDefault();
          const data = new FormData(form);
          fetch(form.action, {
            method: "POST",
            body: data,
            headers: { Accept: "application/json" },
          })
            .then(() => {
              form.classList.add("hidden");
              success.classList.remove("hidden");
            })
            .catch(() => {
              form.classList.add("hidden");
              success.classList.remove("hidden");
            });
        });
      }
    });
  </script>
</Base>

---
import Base from "../../layouts/Base.astro";
import ProductCard from "../../components/ProductCard.astro";
import { getCollection } from "astro:content";
import { categories, categorySlugs } from "../../data/categories";
import { site } from "../../data/site";

const allProducts = await getCollection("products");

const breadcrumbSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Home",
      item: site.url,
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "Shop",
      item: `${site.url}/shop`,
    },
  ],
});
---

<Base
  title="Shop All Handmade Embroidery — Slidell Stitches"
  description="Browse all hand-embroidered products from Slidell Stitches. Wreath sashes, hats, cocktail napkins, baby gifts & more. Handmade in Slidell, Louisiana."
  schema={breadcrumbSchema}
>
  <section class="max-w-7xl mx-auto px-4 py-12">
    <nav class="text-sm text-charcoal-light mb-8">
      <a href="/" class="hover:text-sage transition-colors">Home</a>
      <span class="mx-2">/</span>
      <span class="text-charcoal">Shop</span>
    </nav>

    <h1 class="font-serif text-3xl md:text-4xl text-charcoal mb-2">Shop All Handmade Embroidery</h1>
    <p class="font-body text-charcoal-light mb-8">Browse everything or pick a category below</p>

    <div class="flex flex-wrap gap-2 mb-10" id="filter-bar">
      <button
        data-category="all"
        class="filter-pill bg-sage text-white font-body text-sm px-4 py-2 rounded-full transition-colors"
      >
        All
      </button>
      {categorySlugs.map((slug) => (
        <a
          href={`/shop/${slug}`}
          data-category={slug}
          class="filter-pill bg-sage-light text-charcoal font-body text-sm px-4 py-2 rounded-full transition-colors hover:bg-sage hover:text-white"
        >
          {categories[slug].name}
        </a>
      ))}
    </div>

    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6" id="product-grid">
      {allProducts.map((product) => (
        <div data-product-category={product.data.category}>
          <ProductCard
            name={product.data.name}
            price={product.data.price}
            image={product.data.image}
            imageAlt={product.data.image_alt}
            slug={product.id}
            category={categories[product.data.category].name}
          />
        </div>
      ))}
    </div>
  </section>
</Base>

<script>
  const filterBar = document.getElementById("filter-bar");
  const pills = filterBar?.querySelectorAll(".filter-pill");
  const items = document.querySelectorAll<HTMLElement>("[data-product-category]");

  pills?.forEach((pill) => {
    pill.addEventListener("click", (e) => {
      const target = e.currentTarget as HTMLElement;
      const category = target.dataset.category;

      if (category === "all" || !target.getAttribute("href")) {
        e.preventDefault();
      } else {
        e.preventDefault();
      }

      pills.forEach((p) => {
        p.classList.remove("bg-sage", "text-white");
        p.classList.add("bg-sage-light", "text-charcoal");
      });
      target.classList.remove("bg-sage-light", "text-charcoal");
      target.classList.add("bg-sage", "text-white");

      items.forEach((item) => {
        if (category === "all" || item.dataset.productCategory === category) {
          item.style.display = "";
        } else {
          item.style.display = "none";
        }
      });
    });
  });
</script>

---
import { site } from "../data/site";
import StarRating from "./StarRating.astro";
---

<section class="relative min-h-[50vh] md:min-h-[70vh] flex items-center justify-center bg-cream-dark" style="background-image: repeating-linear-gradient(45deg, transparent, transparent 10px, rgba(0,0,0,0.015) 10px, rgba(0,0,0,0.015) 11px), repeating-linear-gradient(-45deg, transparent, transparent 10px, rgba(0,0,0,0.015) 10px, rgba(0,0,0,0.015) 11px);">
  <div class="text-center px-6 py-16 max-w-3xl mx-auto">
    <h1 class="font-serif text-4xl md:text-5xl lg:text-6xl text-charcoal leading-tight">
      Handmade Embroidery for Every Season
    </h1>
    <p class="font-script text-2xl md:text-3xl text-sage mt-4">
      stitched with love in Slidell, Louisiana
    </p>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mt-8">
      <a href="/shop" class="bg-sage text-white font-body rounded-lg px-8 py-3 hover:bg-sage-dark transition-colors duration-200">
        Shop All
      </a>
      <a href="/custom-orders" class="border-2 border-sage text-sage font-body rounded-lg px-8 py-3 hover:bg-sage hover:text-white transition-colors duration-200">
        Request Custom Order
      </a>
    </div>
    <div class="mt-10 flex flex-col items-center gap-3">
      <StarRating
        rating={site.stats.rating}
        size="md"
        showNumber={true}
        reviewCount={site.stats.reviewCount}
        asLink={site.social.etsyReviews}
      />
      <span class="inline-flex items-center gap-1.5 text-sm font-body text-charcoal-light">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4 text-sage">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
        </svg>
        Stitching from {site.location} since {site.stats.yearStarted}
      </span>
    </div>
  </div>
</section>

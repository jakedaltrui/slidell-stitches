---
interface Props {
  name: string;
  price: number;
  image: string;
  imageAlt: string;
  slug: string;
  category: string;
}

const { name, price, image, imageAlt, slug, category } = Astro.props;
---

<a href={`/products/${slug}`} class="group block cursor-pointer rounded-xl shadow-md hover:shadow-lg transition-shadow duration-300">
  <div class="overflow-hidden rounded-t-xl">
    <picture>
      <source srcset={image.replace('.jpg', '.webp')} type="image/webp" />
      <img
        src={image}
        alt={imageAlt}
        loading="lazy"
        decoding="async"
        width="800"
        height="600"
        class="aspect-[4/3] w-full object-cover hover:brightness-105 hover:saturate-[1.05] transition-all duration-300"
      />
    </picture>
  </div>
  <div class="p-4">
    <h3 class="font-serif text-lg text-charcoal">{name}</h3>
    <p class="font-body font-bold text-gold mt-1">${price.toFixed(2)}</p>
    <span class="inline-block mt-2 bg-sage-light text-white text-xs font-body px-3 py-1 rounded-full">{category}</span>
  </div>
</a>

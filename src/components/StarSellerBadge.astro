---
interface Props {
  size?: "sm" | "md";
  class?: string;
}

const { size = "md", class: className = "" } = Astro.props;

const sizeClasses = {
  sm: "px-2.5 py-1 text-xs gap-1.5",
  md: "px-3 py-1.5 text-sm gap-2",
}[size];

const iconSize = {
  sm: "w-3 h-3",
  md: "w-4 h-4",
}[size];
---

<a
  href="https://www.etsy.com/shop/slidellstitches"
  target="_blank"
  rel="noopener noreferrer"
  title="Star Seller on Etsy — recognized for excellent reviews, on-time shipping, and quick replies"
  class:list={[
    "inline-flex items-center font-body font-semibold rounded-full bg-gold-light/40 text-charcoal border border-gold/40 hover:bg-gold-light/60 transition-colors cursor-pointer",
    sizeClasses,
    className,
  ]}
>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 24 24"
    fill="#C9A96E"
    class:list={[iconSize, "shrink-0"]}
    aria-hidden="true"
  >
    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
  </svg>
  <span>Star Seller on Etsy</span>
</a>

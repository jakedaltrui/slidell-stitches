---
interface Props {
  name: string;
  slug: string;
  image: string;
}

const { name, slug, image } = Astro.props;
---

<a href={`/shop/${slug}`} class="group block cursor-pointer relative overflow-hidden rounded-xl aspect-square md:aspect-[4/3]">
  <div class="absolute inset-0 bg-sage-light">
    {image && (
      <picture>
        <source srcset={image.replace('.jpg', '.webp')} type="image/webp" />
        <img
          src={image}
          alt={name}
          loading="lazy"
          decoding="async"
          width="600"
          height="450"
          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
        />
      </picture>
    )}
  </div>
  <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent group-hover:from-black/30 transition-colors duration-300"></div>
  <div class="absolute bottom-0 left-0 right-0 p-4">
    <h3 class="font-serif text-xl text-white">{name}</h3>
  </div>
</a>
